# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# AgentMail (correo transaccional — welcome, password reset, primera lección,
# payment receipt, failed charge). Sin estas vars, todos los helpers de
# lib/email/send.ts son no-op + warn; no rompen el flujo.
#
# Setup:
#   1. Crear cuenta en https://agentmail.to (ya hecho).
#   2. API Key en dashboard → copiar a AGENTMAIL_API_KEY.
#   3. Inbox ya creado: `itera@agentmail.to` — copiar el ID a AGENTMAIL_INBOX_ID.
#      Si se quiere cambiar sender a dominio custom (p.ej. hola@mail.itera.la),
#      ver docs/EMAIL_DNS_SETUP.md para DKIM/SPF en GoDaddy.
#   4. Reply-to queda en hola@itera.la (Google Workspace) — las respuestas
#      humanas caen en el inbox humano, no en el de AgentMail.
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=itera@agentmail.to
AGENTMAIL_REPLY_TO=hola@itera.la

# Destinatario de notificaciones de leads B2B (form de /empresas). Si no se
# define, cae a AGENTMAIL_REPLY_TO. Se separa porque hola@itera.la puede estar
# bouncando o no quieres que las notificaciones internas mezclen con respuestas
# de clientes. Recomendado: tu correo personal o un alias dedicado.
ENTERPRISE_LEAD_NOTIFY_TO=

# Supabase Auth Send-Email Hook (opcional — para tomar control completo del
# template de password reset, confirm, invite, magic link, etc. desde React
# Email en vez del template HTML del dashboard Supabase). Activar el hook
# en Supabase Dashboard → Auth → Hooks → "Send Email" y pegar:
#   URL: https://itera.la/api/auth/email-hook
#   Secret: el valor que Supabase genere al crear el hook (formato Standard
#   Webhooks: `v1,whsec_<base64>` — el verifier base64-decodifica el tramo
#   después del prefijo para derivar la clave HMAC). Copiar tal cual del
#   dashboard, sin transformaciones.
SUPABASE_AUTH_HOOK_SECRET=

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (used for tutor chat, idea validation, project summary)
OPENAI_API_KEY=sk-xxx

# Cohere (reranker for course generation RAG)
COHERE_API_KEY=your-cohere-api-key

# Recraft (image generation — identidad visual "itera-flat-v1")
# Sacar la key en https://www.recraft.ai/ → settings → API
RECRAFT_API_KEY=

# n8n Webhook (DEPRECATED — course generation is now inline)
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/xxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Preview / dogfooding auto-login secret (server-only, never NEXT_PUBLIC_)
# - Local dev: leave UNSET. /api/dev/auto-login is open in NODE_ENV=development.
# - Production / Vercel preview: set this to a long random string (e.g.
#   `openssl rand -hex 32`) to enable /api/dev/auto-login as a gated entry
#   point. Pass it as `?secret=<value>` or `x-preview-secret: <value>` header.
#   If unset in non-dev, the endpoint stays 404. Rotate to revoke access.
# DEV_AUTO_LOGIN_SECRET=
