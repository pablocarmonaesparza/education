# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Mercado Pago
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=TEST-xxx
MERCADO_PAGO_ACCESS_TOKEN=TEST-xxx

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (used for tutor chat, idea validation, project summary)
OPENAI_API_KEY=sk-xxx

# Cohere (reranker for course generation RAG)
COHERE_API_KEY=your-cohere-api-key

# n8n Webhook (DEPRECATED — course generation is now inline)
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/xxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Preview / dogfooding auto-login secret (server-only, never NEXT_PUBLIC_)
# - Local dev: leave UNSET. /api/dev/auto-login is open in NODE_ENV=development.
# - Production / Vercel preview: set this to a long random string (e.g.
#   `openssl rand -hex 32`) to enable /api/dev/auto-login as a gated entry
#   point. Pass it as `?secret=<value>` or `x-preview-secret: <value>` header.
#   If unset in non-dev, the endpoint stays 404. Rotate to revoke access.
# DEV_AUTO_LOGIN_SECRET=
